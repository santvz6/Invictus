# .env.example - Variables de configuración del proyecto

# ═════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE OLLAMA (LLM Local - Qwen)
# ═════════════════════════════════════════════════════════════════════════

# URL del servidor Ollama (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Modelo Qwen a usar (default: qwen:7b)
OLLAMA_MODEL=qwen:7b

# Timeout para las peticiones a Ollama en segundos
OLLAMA_TIMEOUT=120

# Parámetros de generación de texto
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.9

# ═════════════════════════════════════════════════════════════════════════
# INSTRUCCIONES DE CONFIGURACIÓN
# ═════════════════════════════════════════════════════════════════════════
# 
# 1. Instala Ollama: https://ollama.ai
# 2. Descarga el modelo: ollama pull qwen:7b
# 3. Inicia el servidor: ollama serve
# 4. El dashboard se conectará automáticamente en http://localhost:11434
#
# ═════════════════════════════════════════════════════════════════════════
